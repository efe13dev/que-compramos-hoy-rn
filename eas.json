{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {  
     "distribution": "internal",  
     "autoIncrement": true,  
     "android": {  
      "buildType": "apk",  
      "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a"  
  }  
},
    "production": {
      "autoIncrement": true
    }
  }
}
